{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/maps/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" },
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/join", "destination": "/index.html" },
    { "source": "/map", "destination": "/index.html" },
    { "source": "/family", "destination": "/index.html" },
    { "source": "/alerts", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" },
    { "source": "/simulation", "destination": "/index.html" }
  ]
}

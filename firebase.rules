rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isFamilyMember(familyId) {
      return signedIn() && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }
    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if signedIn() && request.resource.data.guardianUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.guardianUid == request.auth.uid;
      match /{collection}/{documentId} {
        allow read, write: if isFamilyMember(familyId);
      }
    }
  }
}
